{
  "functions": {
    "api/**/*.py": {
      "includeFiles": "{backend/**,kb/**}"
    }
  },
  "rewrites": [
    { "source": "/api/cron", "destination": "/api/cron" },
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 2 * * *"
    }
  ]
}
