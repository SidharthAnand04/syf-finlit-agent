ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Database – Neon (Vercel Storage) ─────────────────────────────────────
# Create via: Vercel dashboard → Storage → Create → Neon Postgres
# Vercel auto-injects both vars into connected projects. For local dev use SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./kb.db?check_same_thread=False
# For production Neon – two URLs, both required:
#   DATABASE_URL        → pooled (pgbouncer) URL used by serverless functions at runtime
#   DATABASE_URL_UNPOOLED → direct URL used by Alembic migrations at build time
#   Mark BOTH as "Available in Build Step" in the Vercel backend project settings.
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1
DATABASE_URL_UNPOOLED=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb

# ── Backend – set in Vercel dashboard (syf-finlit-api project) ────────────
# Mark DATABASE_URL as "Available in Build Step" so Alembic migrations run on deploy.
ADMIN_TOKEN=change-me-strong-secret
CRON_SECRET=change-me-strong-secret
CORS_ORIGIN=https://your-frontend.vercel.app   # comma-sep if multiple

# ── Frontend – set in Vercel dashboard (syf-finlit-frontend project) ──────
NEXT_PUBLIC_BACKEND_URL=https://your-api.vercel.app

# ── Optional RAG tuning ───────────────────────────────────────────────────
RAG_FINAL_TOP_K=4
RAG_LEXICAL_TOP_K=10
RAG_RERANKER_ENABLED=true
